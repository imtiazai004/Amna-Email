rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- PILLAR 0: DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'password'); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- CONNECTIVITY PROBE ---
    match /_internal_/probe {
      allow get: if isSignedIn();
    }
    
    // Multi-tenant check: User's profile must exist in the same school sub-path
    function belongsToSchool(schoolId) {
      return isValidId(schoolId) && 
             isSignedIn() && 
             exists(/databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid));
    }

    function getUserData(schoolId) {
      return get(/databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid)).data;
    }

    function isAdmin(schoolId) {
      return belongsToSchool(schoolId) && getUserData(schoolId).role == 'ADMIN';
    }

    function isTeacher(schoolId) {
      return belongsToSchool(schoolId) && getUserData(schoolId).role == 'TEACHER';
    }

    // --- VALIDATION BLUEPRINTS ---
    
    function isValidUser(data, schoolId) {
      return data.keys().hasAll(['id', 'name', 'email', 'role', 'schoolId']) &&
             data.keys().size() == 5 &&
             data.id == request.auth.uid &&
             data.schoolId == schoolId &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['ADMIN', 'TEACHER', 'STUDENT', 'GUARDIAN'];
    }

    function isValidStudent(data, schoolId) {
      return data.keys().hasAll(['id', 'userId', 'classId', 'guardianId', 'status', 'avatar', 'schoolId']) &&
             data.schoolId == schoolId &&
             data.id is string && data.id.size() <= 128;
    }

    function isValidFee(data, schoolId) {
      return data.keys().hasAll(['id', 'studentId', 'categoryId', 'amountPaid', 'dueDate', 'status', 'schoolId']) &&
             data.schoolId == schoolId;
    }

    // --- MASTER GATE ROUTES ---

    match /schools/{schoolId} {
      allow get: if isSignedIn(); // Allow discovery of school existence
      
      match /users/{userId} {
        allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin(schoolId));
        allow list: if isAdmin(schoolId);
        allow create: if isSignedIn() && isValidUser(incoming(), schoolId);
        allow update: if (isAdmin(schoolId) || request.auth.uid == userId) && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email']);
      }

      match /students/{studentId} {
        allow get: if belongsToSchool(schoolId) && (
          isAdmin(schoolId) || isTeacher(schoolId) ||
          existing().userId == request.auth.uid ||
          // Guardian check
          exists(/databases/$(database)/documents/schools/$(schoolId)/guardians/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/schools/$(schoolId)/guardians/$(request.auth.uid)).data.id == existing().guardianId
        );
        allow list: if belongsToSchool(schoolId);
        allow create, update, delete: if isAdmin(schoolId) && isValidStudent(incoming(), schoolId);
      }

      match /teachers/{teacherId} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /guardians/{guardianId} {
        allow read: if belongsToSchool(schoolId) && (isAdmin(schoolId) || request.auth.uid == guardianId);
        allow write: if isAdmin(schoolId) || (isSignedIn() && request.auth.uid == guardianId);
      }

      match /departments/{id} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /classes/{id} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /subjects/{id} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /schedules/{id} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /attendance/{id} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId) || isTeacher(schoolId);
      }

      match /fees/{id} {
        allow get: if belongsToSchool(schoolId) && (isAdmin(schoolId) || existing().studentId == request.auth.uid);
        allow list: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId) && isValidFee(incoming(), schoolId);
      }

      match /feeCategories/{id} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /events/{id} {
        allow read: if true; // Public events
        allow write: if isAdmin(schoolId);
      }

      match /exams/{id} {
        allow read: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /examResults/{id} {
        allow get: if belongsToSchool(schoolId) && (isAdmin(schoolId) || isTeacher(schoolId) || existing().studentId == request.auth.uid);
        allow list: if belongsToSchool(schoolId);
        allow write: if isAdmin(schoolId) || isTeacher(schoolId);
      }

      match /salaryPayments/{id} {
        allow get: if belongsToSchool(schoolId) && (isAdmin(schoolId) || existing().teacherId == request.auth.uid);
        allow list: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }
    }
  }
}
